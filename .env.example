TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
BASE_URL=https://your-app.up.railway.app
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
AI_KEY=your_openrouter_api_key

# Resend (email via Resend API)
RESEND_API=your_resend_api_key
RESEND_FROM_EMAIL=you@your-domain.com
RESEND_FROM_NAME=Ops Bot

# Supabase (single source of truth for job_entries)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Use CONNECTION POOLER (port 6543) on Railway/serverless — direct (5432) often fails.
# Dashboard → Project Settings → Database → Connection string → Transaction (pooler)
SUPABASE_DB_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Optional: COLUMN_SCHEMA JSON for job_entries (column name -> {description, type})
# COLUMN_SCHEMA={"job_date":{"description":"...","type":"date"},"client_name":{...},...}
